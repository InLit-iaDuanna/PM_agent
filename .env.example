# Leave MINIMAX_API_KEY empty to run the app in deterministic fallback mode.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7

# Default to the China endpoint used by this repository's current environment.
# International MiniMax accounts can switch to https://api.minimax.io/v1.
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# Optional absolute path to opencli if it is not on PATH.
OPENCLI_COMMAND=

# Storage/runtime backend. Keep `json` for single-machine dev, switch to `flagship`
# with PostgreSQL + Redis + S3-compatible object storage for shared deployments.
PM_AGENT_STORAGE_BACKEND=json
PM_AGENT_BACKGROUND_MODE=subprocess
PM_AGENT_POSTGRES_DSN=
PM_AGENT_REDIS_URL=
PM_AGENT_OBJECT_STORAGE_ENDPOINT=
PM_AGENT_OBJECT_STORAGE_BUCKET=
PM_AGENT_OBJECT_STORAGE_ACCESS_KEY=
PM_AGENT_OBJECT_STORAGE_SECRET_KEY=
PM_AGENT_OBJECT_STORAGE_REGION=
PM_AGENT_OBJECT_STORAGE_PREFIX=pm-agent

# Optional comma-separated browser origins allowed to call the API.
# Defaults to loopback origins like http://localhost:3000 and http://127.0.0.1:3000.
PM_AGENT_CORS_ORIGINS=

# Docker deployment: publish the gateway on this host IP + port.
# Keep loopback for the safe default; use a private/VPC IP or `0.0.0.0`
# only when you intentionally want the host to accept external traffic.
PM_AGENT_PUBLIC_BIND_HOST=127.0.0.1
PM_AGENT_PUBLIC_PORT=80

# Docker deployment: use `same-origin` when web and API sit behind one reverse proxy.
PM_AGENT_NEXT_PUBLIC_API_BASE_URL=same-origin

# Optional auth-cookie settings for split-domain deployments.
PM_AGENT_AUTH_COOKIE_SECURE=
PM_AGENT_AUTH_COOKIE_SAMESITE=lax

# Account-system controls
PM_AGENT_ALLOW_PUBLIC_REGISTRATION=true
PM_AGENT_REGISTRATION_INVITE_CODE=
