FROM python:3.12-slim

ARG PM_AGENT_BUILD_COMMIT=unknown
ARG PM_AGENT_BUILD_TAG=
ARG PM_AGENT_BUILD_BRANCH=
ARG PM_AGENT_BUILD_TIME=

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPYCACHEPREFIX=/tmp/pm-agent-pycache \
    PM_AGENT_STATE_DIR=/data/state \
    PIP_NO_CACHE_DIR=1 \
    PM_AGENT_BUILD_COMMIT=${PM_AGENT_BUILD_COMMIT} \
    PM_AGENT_BUILD_TAG=${PM_AGENT_BUILD_TAG} \
    PM_AGENT_BUILD_BRANCH=${PM_AGENT_BUILD_BRANCH} \
    PM_AGENT_BUILD_TIME=${PM_AGENT_BUILD_TIME}

WORKDIR /app

RUN mkdir -p /data/state \
    && pip install --upgrade pip \
    && pip install \
      "fastapi>=0.110.0" \
      "uvicorn>=0.29.0" \
      "pydantic>=2.6.0" \
      "httpx>=0.27.0" \
      "beautifulsoup4>=4.12.0" \
      "psycopg[binary]>=3.2.0" \
      "redis>=5.2.0" \
      "boto3>=1.35.0"

COPY apps ./apps
COPY packages ./packages

ENV PYTHONPATH=/app/apps/api:/app/apps/worker:/app

WORKDIR /app/apps/api

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "pm_agent_api.main:app", "--host", "0.0.0.0", "--port", "8000", "--proxy-headers", "--forwarded-allow-ips=*"]
