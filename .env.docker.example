# Core runtime
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
OPENCLI_COMMAND=

# Flagship storage/runtime baseline
# IMPORTANT: These demo credentials are for local compose only.
# For any public/server deployment, replace Postgres and object-storage
# passwords/access keys with strong secrets before first startup.
PM_AGENT_STORAGE_BACKEND=flagship
PM_AGENT_BACKGROUND_MODE=worker
PM_AGENT_POSTGRES_DB=pmagent
PM_AGENT_POSTGRES_USER=pmagent
PM_AGENT_POSTGRES_PASSWORD=pmagent
PM_AGENT_POSTGRES_DSN=postgresql://pmagent:pmagent@postgres:5432/pmagent
PM_AGENT_REDIS_URL=redis://redis:6379/0
PM_AGENT_OBJECT_STORAGE_ENDPOINT=http://object-storage:9000
PM_AGENT_OBJECT_STORAGE_BUCKET=pm-agent
PM_AGENT_OBJECT_STORAGE_ACCESS_KEY=minioadmin
PM_AGENT_OBJECT_STORAGE_SECRET_KEY=minioadmin
PM_AGENT_OBJECT_STORAGE_REGION=us-east-1
PM_AGENT_OBJECT_STORAGE_PREFIX=pm-agent

# HTTP/staging deploy with docker-compose.yml
# Safe default: bind the host port on loopback only.
# For cloud/LB/WAF deployments, prefer the server's private/VPC IP.
# Use 0.0.0.0 only if you intentionally want direct host exposure.
PM_AGENT_PUBLIC_BIND_HOST=127.0.0.1
PM_AGENT_PUBLIC_PORT=80

# Public production deploy with docker-compose.prod.yml + Caddy
# For real internet deploys, set this to your public domain, for example: research.example.com
PM_AGENT_SITE_ADDRESS=research.example.com
# Safe defaults: keep the source stack on loopback until you explicitly choose an edge address.
# For a load balancer / WAF / reverse proxy, bind these to the server's private/VPC IP.
# Use 0.0.0.0 only if you intentionally want the host itself to accept direct internet traffic.
PM_AGENT_HTTP_BIND_HOST=127.0.0.1
PM_AGENT_HTTPS_BIND_HOST=127.0.0.1
PM_AGENT_HTTP_PORT=80
PM_AGENT_HTTPS_PORT=443

# Default to same-origin so nginx can expose the app as a single website.
# Set this to an absolute public API URL only if you intentionally split web/api across domains.
PM_AGENT_NEXT_PUBLIC_API_BASE_URL=same-origin

# Optional cross-site settings for split-domain deployments.
# When web and API use different public origins, set `PM_AGENT_CORS_ORIGINS` to the web origin,
# keep credentials enabled, and review the cookie settings below together.
PM_AGENT_CORS_ORIGINS=
# If you terminate HTTPS in front of nginx or expose this stack behind TLS, set this to `true`.
PM_AGENT_AUTH_COOKIE_SECURE=
PM_AGENT_AUTH_COOKIE_SAMESITE=lax

# Account-system controls
# Safer default for public/server deployments: bootstrap the first admin, then require invites unless you reopen registration.
PM_AGENT_ALLOW_PUBLIC_REGISTRATION=false
PM_AGENT_REGISTRATION_INVITE_CODE=

# Optional one-time deploy helper values for ./scripts/docker_deploy_prod.sh
# PM_AGENT_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# PM_AGENT_BOOTSTRAP_ADMIN_PASSWORD=change-me-before-real-deploy
# PM_AGENT_BOOTSTRAP_ADMIN_DISPLAY_NAME=PM Admin
