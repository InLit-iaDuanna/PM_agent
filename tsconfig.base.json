{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@pm-agent/ui": ["packages/ui/src/index.ts"],
      "@pm-agent/ui/*": ["packages/ui/src/*"],
      "@pm-agent/types": ["packages/types/src/index.ts"],
      "@pm-agent/types/*": ["packages/types/src/*"],
      "@pm-agent/research-core": ["packages/research-core/src/index.ts"],
      "@pm-agent/research-core/*": ["packages/research-core/src/*"],
      "@pm-agent/config/*": ["packages/config/*"]
    }
  }
}

